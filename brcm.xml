<?xml version="1.0" encoding="UTF-8"?>
<!--
  Raspberry Vanilla projects — merged from upstream
  https://github.com/raspberry-vanilla/android_local_manifest
  (manifest_brcm_rpi.xml + manifest_utilities.xml).

  Every project below is pinned to a specific commit SHA so this manifest
  is reproducible: re-running `repo sync` will not pull in newer upstream
  changes. To bump, edit the revision="..." attributes in this file.

  SHAs captured 2026-05-02 from the working checkout under /mnt/build/aosp.
-->
