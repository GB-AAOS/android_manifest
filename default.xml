<?xml version="1.0" encoding="UTF-8"?>
<!--
  gborges AOSP manifest — composes three sources:

    1. google/default.xml                   verbatim AOSP platform/manifest
                                            (see google/SOURCE.md)
    2. raspberry-vanilla/manifest_brcm_rpi.xml
       raspberry-vanilla/manifest_utilities.xml
                                            verbatim Raspberry Vanilla local
                                            manifest (see raspberry-vanilla/SOURCE.md)
    3. gborges.xml                          gborges-owned projects (GB-AAOS/*)

  Order matters: google/ must come first so the <remove-project> directives
  in raspberry-vanilla/ can resolve their targets. gborges sits last to
  override anything in either source if needed.
-->
<manifest>
  <include name="google/default.xml" />
  <include name="raspberry-vanilla/manifest_brcm_rpi.xml" />
  <include name="raspberry-vanilla/manifest_utilities.xml" />
  <include name="raspberry-vanilla/remove_projects.xml" />
  <include name="gborges.xml" />
</manifest>
