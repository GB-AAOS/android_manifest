           remote="gb-aaos"
           revision="refs/heads/gbrpi-0.24.13"
           upstream="gbrpi-0.24.13" />

  <!-- NanoNNG -->
  <project path="external/nanonng" name="external_nanonng"
           remote="gb-aaos"
           revision="refs/heads/gbrpi-95d675bc"
           upstream="gbrpi-95d675bc" />

